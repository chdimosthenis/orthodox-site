---
interface Props {
  slug: string;
  title: string;
  description: string;
  /** Kept for back-compat but no longer rendered (Greek-only site). */
  pubDate?: Date;
  /** Kept for back-compat but no longer rendered (Greek-only site). */
  language?: 'el' | 'en';
}

const { slug, title, description } = Astro.props;
---

<article class="card">
  <h3>
    <a href={`/articles/${slug}`}>{title}</a>
  </h3>
  <p class="description">{description}</p>
</article>

<style>
  .card {
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .card:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.3rem;
  }
  .card h3 a {
    color: var(--color-text);
    border-bottom: none;
  }
  .card h3 a:hover {
    color: var(--color-accent);
  }
  .description {
    margin: 0 0 0.5rem;
    color: var(--color-muted);
  }
</style>
