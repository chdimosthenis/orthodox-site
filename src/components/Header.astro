---
import { useTranslations } from '../i18n/utils';

const t = useTranslations('el');

// Top-level navigation: 7 items, each leading to a hub or single page.
// Sub-sections live within hubs (Διδασκαλία, Πρόσωπα, Λατρεία) and are
// rendered alphabetically on those pages.
const navItems = [
  { label: t('nav.news'),        path: '/news/' },
  { label: t('nav.bible'),       path: '/bible' },          // "Καινὴ Διαθήκη"
  { label: t('nav.didaskalia'),  path: '/didaskalia' },     // hub: Ἄρθρα + Θεολογία + Ἱστορία
  { label: t('nav.prosopa'),     path: '/prosopa' },        // hub: Ἅγιοι + Πατέρες
  { label: t('nav.latreia'),     path: '/latreia' },        // hub: Ἀκολουθίες, Ἑορτολόγιον, Μοναστήρια, Ναὸς & Λατρεία, Προσευχητάριον, Ὕμνοι
  { label: t('nav.search'),      path: '/search/' },
  { label: t('nav.about'),       path: '/about' },
];
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="brand" aria-label={t('site.title')}>
      <span class="brand-mark" aria-hidden="true">☦</span>
      <span class="brand-text">{t('site.title')}</span>
    </a>
    <nav aria-label="primary">
      <ul>
        {navItems.map(item => (
          <li>
            <a href={item.path}>{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
  }
  .header-inner {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .brand {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    color: var(--color-text);
    text-decoration: none;
    border-bottom: none;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    letter-spacing: 0.005em;
  }
  .brand-mark {
    color: var(--color-gold);
    font-size: 1.6rem;
    line-height: 1;
  }
  nav {
    flex: 1;
  }
  nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  nav a {
    font-size: 0.95rem;
    color: var(--color-muted);
    text-decoration: none;
    border-bottom: none;
    padding: 0.25rem 0;
  }
  nav a:hover {
    color: var(--color-accent);
  }
  @media (max-width: 720px) {
    nav { width: 100%; order: 3; }
    nav ul { gap: 1rem; }
  }
</style>
