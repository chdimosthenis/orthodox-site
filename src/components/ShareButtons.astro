---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const xUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(url)}`;
const fbUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`;
const waUrl = `https://wa.me/?text=${encodeURIComponent(`${title} ${url}`)}`;
const tgUrl = `https://t.me/share/url?url=${encodeURIComponent(url)}&text=${encodeURIComponent(title)}`;
const liUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`;
const mailUrl = `mailto:?subject=${encodeURIComponent(title)}&body=${encodeURIComponent(url)}`;
---

<aside class="share-bar" aria-label={t('share.title')}>
  <span class="share-label">{t('share.title')}</span>
  <ul class="share-list">
    <li>
      <a class="share-btn" href={xUrl} target="_blank" rel="noopener noreferrer" aria-label={`${t('share.via')} X`}>
        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
          <path fill="currentColor" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.23zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
        </svg>
        <span>X</span>
      </a>
    </li>
    <li>
      <a class="share-btn" href={fbUrl} target="_blank" rel="noopener noreferrer" aria-label={`${t('share.via')} Facebook`}>
        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
          <path fill="currentColor" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
        </svg>
        <span>Facebook</span>
      </a>
    </li>
    <li>
      <a class="share-btn" href={waUrl} target="_blank" rel="noopener noreferrer" aria-label={`${t('share.via')} WhatsApp`}>
        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
          <path fill="currentColor" d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.595 5.36L1.83 22.49l5.824-2.297zM17.41 14.382c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.521.074-.793.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/>
        </svg>
        <span>WhatsApp</span>
      </a>
    </li>
    <li>
      <a class="share-btn" href={tgUrl} target="_blank" rel="noopener noreferrer" aria-label={`${t('share.via')} Telegram`}>
        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
          <path fill="currentColor" d="M11.944 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0a12 12 0 00-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 01.171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
        </svg>
        <span>Telegram</span>
      </a>
    </li>
    <li>
      <a class="share-btn" href={liUrl} target="_blank" rel="noopener noreferrer" aria-label={`${t('share.via')} LinkedIn`}>
        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
          <path fill="currentColor" d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        <span>LinkedIn</span>
      </a>
    </li>
    <li>
      <a class="share-btn" href={mailUrl} aria-label={`${t('share.via')} email`}>
        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
          <path fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" d="M3 6h18v12H3zM3 6l9 7 9-7"/>
        </svg>
        <span>Email</span>
      </a>
    </li>
    <li>
      <button class="share-btn" type="button" data-share-copy data-url={url} data-label-copy={t('share.copy')} data-label-copied={t('share.copied')}>
        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
          <path fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" d="M9.5 14.5a4 4 0 005.66 0l3-3a4 4 0 00-5.66-5.66l-1.5 1.5M14.5 9.5a4 4 0 00-5.66 0l-3 3a4 4 0 005.66 5.66l1.5-1.5"/>
        </svg>
        <span>{t('share.copy')}</span>
      </button>
    </li>
    <li hidden data-share-native-li>
      <button class="share-btn" type="button" data-share-native data-url={url} data-title={title} aria-label={t('share.title')}>
        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
          <path fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" d="M12 16V4m0 0l-4 4m4-4l4 4M4 14v4a2 2 0 002 2h12a2 2 0 002-2v-4"/>
        </svg>
        <span>{t('share.title')}</span>
      </button>
    </li>
  </ul>
</aside>

<script>
  // Reveal native-share button only where supported
  if (typeof navigator !== 'undefined' && typeof navigator.share === 'function') {
    document.querySelectorAll('[data-share-native-li]').forEach(li => {
      li.removeAttribute('hidden');
    });
    document.querySelectorAll('[data-share-native]').forEach(el => {
      const btn = el as HTMLButtonElement;
      btn.addEventListener('click', async () => {
        const url = btn.getAttribute('data-url') ?? location.href;
        const title = btn.getAttribute('data-title') ?? document.title;
        try {
          await navigator.share({ title, url });
        } catch (err) {
          // User cancelled or share failed — silent
        }
      });
    });
  }

  // Copy-link buttons
  document.querySelectorAll('[data-share-copy]').forEach(el => {
    const btn = el as HTMLButtonElement;
    const labelEl = btn.querySelector('span');
    const original = btn.getAttribute('data-label-copy') ?? labelEl?.textContent ?? '';
    const copied = btn.getAttribute('data-label-copied') ?? 'Copied';
    btn.addEventListener('click', async () => {
      const url = btn.getAttribute('data-url') ?? location.href;
      try {
        await navigator.clipboard.writeText(url);
      } catch (err) {
        // Fallback: select & execCommand on a hidden textarea
        const ta = document.createElement('textarea');
        ta.value = url;
        ta.setAttribute('readonly', '');
        ta.style.position = 'absolute';
        ta.style.left = '-9999px';
        document.body.appendChild(ta);
        ta.select();
        try { document.execCommand('copy'); } catch (_) { /* swallow */ }
        document.body.removeChild(ta);
      }
      if (labelEl) {
        labelEl.textContent = copied;
        btn.classList.add('is-copied');
        setTimeout(() => {
          labelEl.textContent = original;
          btn.classList.remove('is-copied');
        }, 1800);
      }
    });
  });
</script>

<style>
  .share-bar {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.85rem 1rem;
  }
  .share-label {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
  }
  .share-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: transparent;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-muted);
    text-decoration: none;
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .share-btn:hover,
  .share-btn:focus-visible {
    border-color: var(--color-accent);
    color: var(--color-accent);
    outline: none;
  }
  .share-btn svg {
    flex-shrink: 0;
  }
  .share-btn.is-copied {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }
</style>
