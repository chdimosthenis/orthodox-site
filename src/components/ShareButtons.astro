---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const xUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(url)}`;
const fbUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`;
const mailUrl = `mailto:?subject=${encodeURIComponent(title)}&body=${encodeURIComponent(url)}`;
---

<aside class="share-bar" aria-label={t('share.title')}>
  <span class="share-label">{t('share.title')}</span>
  <ul class="share-list">
    <li>
      <a class="share-btn" href={xUrl} target="_blank" rel="noopener noreferrer" aria-label={`${t('share.via')} X`}>
        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
          <path fill="currentColor" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.23zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
        </svg>
        <span>X</span>
      </a>
    </li>
    <li>
      <a class="share-btn" href={fbUrl} target="_blank" rel="noopener noreferrer" aria-label={`${t('share.via')} Facebook`}>
        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
          <path fill="currentColor" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
        </svg>
        <span>Facebook</span>
      </a>
    </li>
    <li>
      <a class="share-btn" href={mailUrl} aria-label={`${t('share.via')} email`}>
        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
          <path fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" d="M3 6h18v12H3zM3 6l9 7 9-7"/>
        </svg>
        <span>Email</span>
      </a>
    </li>
    <li>
      <button class="share-btn" type="button" data-share-copy data-url={url} data-label-copy={t('share.copy')} data-label-copied={t('share.copied')}>
        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
          <path fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" d="M9.5 14.5a4 4 0 005.66 0l3-3a4 4 0 00-5.66-5.66l-1.5 1.5M14.5 9.5a4 4 0 00-5.66 0l-3 3a4 4 0 005.66 5.66l1.5-1.5"/>
        </svg>
        <span>{t('share.copy')}</span>
      </button>
    </li>
    <li hidden data-share-native-li>
      <button class="share-btn" type="button" data-share-native data-url={url} data-title={title} aria-label={t('share.title')}>
        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
          <path fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" d="M12 16V4m0 0l-4 4m4-4l4 4M4 14v4a2 2 0 002 2h12a2 2 0 002-2v-4"/>
        </svg>
        <span>{t('share.title')}</span>
      </button>
    </li>
  </ul>
</aside>

<script>
  // Reveal native-share button only where supported
  if (typeof navigator !== 'undefined' && typeof navigator.share === 'function') {
    document.querySelectorAll('[data-share-native-li]').forEach(li => {
      li.removeAttribute('hidden');
    });
    document.querySelectorAll('[data-share-native]').forEach(el => {
      const btn = el as HTMLButtonElement;
      btn.addEventListener('click', async () => {
        const url = btn.getAttribute('data-url') ?? location.href;
        const title = btn.getAttribute('data-title') ?? document.title;
        try {
          await navigator.share({ title, url });
        } catch (err) {
          // User cancelled or share failed — silent
        }
      });
    });
  }

  // Copy-link buttons
  document.querySelectorAll('[data-share-copy]').forEach(el => {
    const btn = el as HTMLButtonElement;
    const labelEl = btn.querySelector('span');
    const original = btn.getAttribute('data-label-copy') ?? labelEl?.textContent ?? '';
    const copied = btn.getAttribute('data-label-copied') ?? 'Copied';
    btn.addEventListener('click', async () => {
      const url = btn.getAttribute('data-url') ?? location.href;
      try {
        await navigator.clipboard.writeText(url);
      } catch (err) {
        // Fallback: select & execCommand on a hidden textarea
        const ta = document.createElement('textarea');
        ta.value = url;
        ta.setAttribute('readonly', '');
        ta.style.position = 'absolute';
        ta.style.left = '-9999px';
        document.body.appendChild(ta);
        ta.select();
        try { document.execCommand('copy'); } catch (_) { /* swallow */ }
        document.body.removeChild(ta);
      }
      if (labelEl) {
        labelEl.textContent = copied;
        btn.classList.add('is-copied');
        setTimeout(() => {
          labelEl.textContent = original;
          btn.classList.remove('is-copied');
        }, 1800);
      }
    });
  });
</script>

<style>
  .share-bar {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.85rem 1rem;
  }
  .share-label {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
  }
  .share-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: transparent;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-muted);
    text-decoration: none;
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .share-btn:hover,
  .share-btn:focus-visible {
    border-color: var(--color-accent);
    color: var(--color-accent);
    outline: none;
  }
  .share-btn svg {
    flex-shrink: 0;
  }
  .share-btn.is-copied {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }
</style>
