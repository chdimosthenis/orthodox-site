---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={t('about.title')}>
  <h1>{t('about.title')}</h1>
  <p>{t('about.body')}</p>

  <h2>{t('about.mission.heading')}</h2>
  <p>{t('about.mission.body')}</p>

  <div class="ai-disclaimer">
    <h2>{t('about.disclaimer.heading')}</h2>
    <p>{t('about.disclaimer.body')}</p>
  </div>

  <h2>{t('about.contact.heading')}</h2>
  <p>{t('about.contact.body')} <a href="mailto:info@orthodoxoskomvos.gr">info@orthodoxoskomvos.gr</a>.</p>
</BaseLayout>

<style>
  .ai-disclaimer {
    margin-top: 2rem;
    padding: 1rem 1.25rem;
    border-left: 3px solid var(--color-accent, #b8860b);
    background: var(--color-surface, #faf7f1);
    border-radius: 2px;
  }
  .ai-disclaimer h2 {
    margin-top: 0;
    font-size: 1.1rem;
  }
  .ai-disclaimer p {
    margin-bottom: 0;
    font-size: 0.95rem;
  }
</style>
