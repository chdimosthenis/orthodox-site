---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import { getCollection, render } from 'astro:content';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../../i18n/utils';

export async function getStaticPaths() {
  const books = await getCollection('bible');
  return books
    .filter(b => b.data.language === 'el')
    .map(b => ({ params: { slug: b.id }, props: { entry: b } }));
}

const { entry } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { Content } = await render(entry);
const shareUrl = new URL(Astro.url.pathname, Astro.site).toString();

const chapterCount = entry.data.chapters ?? 0;
const tocChapters = Array.from({ length: chapterCount }, (_, i) => i + 1);

const jsonld = {
  '@context': 'https://schema.org',
  '@type': 'Book',
  name: entry.data.book,
  alternateName: entry.data.bookEnglish,
  inLanguage: entry.data.language,
  bookFormat: 'EBook',
  isPartOf: { '@type': 'Book', name: 'Ἡ Καινὴ Διαθήκη' },
};
---

<BaseLayout title={entry.data.book} jsonld={jsonld} wide>
  <article>
    <header class="bible-header">
      <p class="metadata">
        <a href={getLocalizedPath('/bible', lang)}>← {t('bible.title')}</a>
      </p>
      <h1 lang={entry.data.language}>{entry.data.book}</h1>
      {entry.data.bookEnglish && (
        <p class="bible-subtitle muted">{entry.data.bookEnglish}</p>
      )}
    </header>

    {tocChapters.length > 1 && (
      <nav class="bible-toc" aria-label={t('bible.toc')}>
        <p class="toc-label">{t('bible.toc')}</p>
        <ul>
          {tocChapters.map(c => (
            <li><a href={`#kefalaion-${c}`}>{c}</a></li>
          ))}
        </ul>
      </nav>
    )}

    <div class="bible-body polytonic" lang={entry.data.language}>
      <Content />
    </div>

    <footer class="attribution">
      <p>
        <strong>{t('source')}:</strong>{' '}
        <a href={entry.data.sourceUrl} rel="noopener external">{entry.data.sourceUrl}</a>
      </p>
    </footer>

    <ShareButtons title={entry.data.book} url={shareUrl} />
  </article>
</BaseLayout>

<style>
  .bible-header {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }
  .bible-header h1 { margin-top: 0.5rem; }
  .bible-subtitle {
    margin: 0.25rem 0 0;
    font-style: italic;
    font-size: 1.05rem;
  }
  .bible-toc {
    margin: 0 0 2rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-byzantine-purple, #4a1e50);
    border-radius: 0 4px 4px 0;
    background: var(--color-attribution-bg);
  }
  .bible-toc .toc-label {
    margin: 0 0 0.6rem;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
  }
  .bible-toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .bible-toc li a {
    display: inline-block;
    min-width: 2.4rem;
    padding: 0.3rem 0.6rem;
    text-align: center;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    border-bottom: 1px solid var(--color-border);
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-muted);
  }
  .bible-toc li a:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .bible-body :global(h2) {
    margin-top: 2.5rem;
    padding-top: 0.5rem;
    border-top: 1px dashed var(--color-border);
    font-size: 1.4rem;
    color: var(--color-byzantine-purple, #4a1e50);
    scroll-margin-top: 1rem;
  }
  .bible-body :global(h2::before) { content: ""; }
</style>

<script>
  // Inject id attributes on h2 headings so the TOC anchors work.
  document.querySelectorAll('.bible-body h2').forEach((h2, idx) => {
    if (!h2.id) {
      const m = h2.textContent?.match(/(\d+)/);
      if (m) h2.id = `kefalaion-${m[1]}`;
    }
  });
</script>
