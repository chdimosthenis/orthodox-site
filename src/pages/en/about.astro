---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={t('about.title')}>
  <h1>{t('about.title')}</h1>
  <p>{t('about.body')}</p>
</BaseLayout>
