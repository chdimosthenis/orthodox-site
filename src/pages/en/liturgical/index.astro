---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../../../i18n/utils';
import type { UIKey } from '../../../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const items = (await getCollection('liturgical'))
  .filter(l => l.data.language === lang)
  .sort((a, b) => a.data.title.localeCompare(b.data.title, lang));

const sections = [
  {
    id: 'services',
    title: t('lit.section.services'),
    types: ['apodeipno', 'paraklesis', 'chairetismoi', 'akathistos', 'theia-metalipsi', 'akolouthia'] as const,
  },
  {
    id: 'prayers',
    title: t('lit.section.prayers'),
    types: ['prayer'] as const,
  },
  {
    id: 'hymns',
    title: t('lit.section.hymns'),
    types: ['tropar', 'kontak', 'hymn', 'ode'] as const,
  },
];

const grouped = sections
  .map(s => ({ ...s, items: items.filter(i => (s.types as readonly string[]).includes(i.data.type)) }))
  .filter(s => s.items.length > 0);
---

<BaseLayout title={t('all.liturgical')}>
  <h1>{t('all.liturgical')}</h1>
  {grouped.length === 0 ? (
    <p class="muted">{t('no.entries')}</p>
  ) : grouped.map(section => (
    <section class="lit-section" id={section.id}>
      <h2>{section.title}</h2>
      <ul class="card-list">
        {section.items.map(item => (
          <li class="lit-card">
            <h3>
              <a href={getLocalizedPath(`/liturgical/${item.id}`, lang)} lang={item.data.language}>{item.data.title}</a>
            </h3>
            <p class="metadata">{t(`type.${item.data.type}` as UIKey)}</p>
          </li>
        ))}
      </ul>
    </section>
  ))}
</BaseLayout>

<style>
  .lit-section + .lit-section { margin-top: 3rem; }
  .lit-section h2 {
    margin-top: 0;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .lit-card {
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }
  .lit-card:last-child { border-bottom: none; padding-bottom: 0; }
  .lit-card h3 { margin: 0 0 0.35rem; font-size: 1.2rem; }
  .lit-card h3 a { color: var(--color-text); border-bottom: none; }
  .lit-card h3 a:hover { color: var(--color-accent); }
</style>
