---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../../i18n/utils';
import type { UIKey } from '../../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const clusters = [
  { id: 'councils',       primaryTag: 'ecumenical-council', titleKey: 'history.section.councils'      },
  { id: 'patriarchates',  primaryTag: 'patriarchate',       titleKey: 'history.section.patriarchates' },
  { id: 'autocephalous',  primaryTag: 'autocephalous',      titleKey: 'history.section.autocephalous' },
  { id: 'schisms',        primaryTag: 'schism',             titleKey: 'history.section.schisms'       },
  { id: 'councils-other', primaryTag: 'council',            titleKey: 'history.section.councilsOther' },
] as const;

export async function getStaticPaths() {
  const ids = ['councils', 'patriarchates', 'autocephalous', 'schisms', 'councils-other'];
  return ids.map(id => ({ params: { cluster: id } }));
}

const { cluster } = Astro.params;
const c = clusters.find(x => x.id === cluster);
if (!c) return Astro.redirect('/history');

const greekOnly = lang === 'el';
const articles = (await getCollection('articles'))
  .filter(a => !a.data.draft && a.data.tags && a.data.tags.includes(c.primaryTag))
  .filter(a => !greekOnly || a.data.language === 'el')
  .sort((a, b) => a.data.title.localeCompare(b.data.title, lang));

const localeTag = lang === 'el' ? 'el-GR' : 'en-GB';
const sectionTitle = t(c.titleKey as UIKey);
---

<BaseLayout title={sectionTitle}>
  <p class="breadcrumb">
    <a href={getLocalizedPath('/history', lang)}>← {t('history.title')}</a>
  </p>
  <h1>{sectionTitle}</h1>

  {articles.length === 0 ? (
    <p class="muted empty-state">
      {greekOnly
        ? 'Δὲν ὑπάρχουν ἀκόμη ἑλληνικὰ ἄρθρα σὲ αὐτὴ τὴν ὑποενότητα. Νέα κείμενα προστίθενται περιοδικὰ μὲ τὴν αὐτόματη συγγραφικὴ ροή.'
        : t('no.entries')}
    </p>
  ) : (
    <ul class="card-list">
      {articles.map(a => (
        <li class="history-card">
          <h3>
            <a href={getLocalizedPath(`/articles/${a.id}`, lang)} lang={a.data.language}>{a.data.title}</a>
          </h3>
          {a.data.description && a.data.description !== a.data.title && (
            <p class="muted">{a.data.description}</p>
          )}
        </li>
      ))}
    </ul>
  )}
</BaseLayout>

<style>
  .breadcrumb { margin-bottom: 0.5rem; font-size: 0.95rem; }
  .breadcrumb a { color: var(--color-muted, #6e6452); border-bottom: none; }
  .breadcrumb a:hover { color: var(--color-accent); }
  .empty-state { padding: 2rem 0; }
  .history-card {
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }
  .history-card:last-child { border-bottom: none; padding-bottom: 0; }
  .history-card h3 { margin: 0 0 0.35rem; font-size: 1.2rem; }
  .history-card h3 a { color: var(--color-text); border-bottom: none; }
  .history-card h3 a:hover { color: var(--color-accent); }
  .history-card p { margin: 0.25rem 0 0; }
</style>
