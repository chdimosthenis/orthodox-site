---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../../i18n/utils';
import type { UIKey } from '../../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const articles = (await getCollection('articles'))
  .filter(a => !a.data.draft && a.data.tags && a.data.language === 'el');

const sections = [
  { id: 'architecture', primaryTag: 'naos-architecture', titleKey: 'naos.section.architecture' },
  { id: 'vestments',    primaryTag: 'naos-vestments',    titleKey: 'naos.section.vestments'    },
  { id: 'orders',       primaryTag: 'naos-orders',       titleKey: 'naos.section.orders'       },
] as const;

const counts: Record<string, number> = {};
for (const s of sections) {
  counts[s.id] = articles.filter(a => a.data.tags!.includes(s.primaryTag)).length;
}

const sortedSections = [...sections]
  .map(s => ({ ...s, title: t(s.titleKey as UIKey) }))
  .sort((a, b) => a.title.localeCompare(b.title, 'el-GR'));
---

<BaseLayout title={t('naos.title')}>
  <h1>{t('naos.title')}</h1>
  <p class="muted">{t('naos.intro')}</p>

  <ul class="cluster-grid">
    {sortedSections.map(s => (
      <li class={`cluster-card ${counts[s.id] === 0 ? 'is-empty' : ''}`}>
        <a href={getLocalizedPath(`/naos-kai-latreia/${s.id}`, lang)}>
          <h2>{s.title}</h2>
          <p class="muted count">
            {counts[s.id] === 0
              ? 'σύντομα'
              : `${counts[s.id]} ${counts[s.id] === 1 ? 'ἄρθρο' : 'ἄρθρα'}`}
          </p>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .cluster-grid {
    list-style: none;
    padding: 0;
    margin: 2rem 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }
  .cluster-card {
    border: 1px solid var(--color-border);
    border-radius: 4px;
    transition: border-color 0.15s;
  }
  .cluster-card:hover { border-color: var(--color-accent); }
  .cluster-card.is-empty { opacity: 0.55; }
  .cluster-card a {
    display: block;
    padding: 1.1rem 1.2rem;
    color: var(--color-text);
    border-bottom: none;
    height: 100%;
  }
  .cluster-card h2 {
    margin: 0 0 0.35rem;
    font-size: 1.1rem;
    line-height: 1.25;
  }
  .cluster-card .count {
    margin: 0;
    font-size: 0.88rem;
    font-variant-numeric: tabular-nums;
  }
</style>
