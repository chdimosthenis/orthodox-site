---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils';
import type { UIKey } from '../../i18n/ui';

type NewsItem = {
  title: string;
  url: string;
  source: string;
  host: string;
  published: string | null;
  excerpt: string;
  category: string;
};

type ArchiveData = {
  generated_at: string;
  date?: string;
  count: number;
  items: NewsItem[];
};

export async function getStaticPaths() {
  const archives = import.meta.glob<{ default: ArchiveData }>(
    '../../data/news/*.json',
    { eager: true }
  );
  return Object.entries(archives)
    .map(([path, mod]) => {
      const m = path.match(/(\d{4}-\d{2}-\d{2})\.json$/);
      if (!m) return null;
      return { params: { date: m[1] }, props: { data: mod.default } };
    })
    .filter((p): p is { params: { date: string }; props: { data: ArchiveData } } => p !== null);
}

const t = useTranslations('el');
const { date } = Astro.params;
const { data } = Astro.props;
const items = data.items;

const formatLong = (iso: string) => {
  const [y, m, d] = iso.split('-').map(Number);
  return new Date(y, m - 1, d).toLocaleDateString('el-GR', {
    weekday: 'long', day: 'numeric', month: 'long', year: 'numeric',
  });
};

const generatedAt = new Date(data.generated_at).toLocaleString('el-GR', {
  dateStyle: 'medium', timeStyle: 'short',
});
---

<BaseLayout title={`Νέα · ${formatLong(date!)}`}>
  <p class="back-link"><a href="/news/archive">← Ἀρχεῖο Νέων</a></p>
  <h1>Νέα τῆς {formatLong(date!)}</h1>
  <p class="metadata">Στιγμιότυπο: <time datetime={data.generated_at}>{generatedAt}</time></p>

  <ul class="news-page-list">
    {items.map(item => (
      <li class="news-page-item">
        <p class="news-page-meta">
          <span class="news-page-source">{item.source}</span>
          {item.published && (
            <>
              {' · '}
              <time datetime={item.published}>
                {new Date(item.published).toLocaleDateString('el-GR', { day: 'numeric', month: 'long', year: 'numeric' })}
              </time>
            </>
          )}
          {item.category && item.category !== 'general' && (
            <>
              {' · '}
              <span class="news-page-category">{t(`news.cat.${item.category}` as UIKey)}</span>
            </>
          )}
        </p>
        <h3>
          <a href={item.url} target="_blank" rel="noopener noreferrer">{item.title}</a>
        </h3>
        {item.excerpt && <p class="news-page-excerpt muted">{item.excerpt}</p>}
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .back-link {
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }
  .news-page-list {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
    display: grid;
    gap: 2rem;
  }
  .news-page-item {
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .news-page-item:last-child { border-bottom: none; padding-bottom: 0; }
  .news-page-item h3 {
    margin: 0.4rem 0 0.5rem;
    font-size: 1.25rem;
  }
  .news-page-item h3 a {
    color: var(--color-text);
    border-bottom: none;
  }
  .news-page-item h3 a:hover { color: var(--color-accent); }
  .news-page-meta {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-muted);
  }
  .news-page-source { font-weight: 600; color: var(--color-gold); }
  .news-page-category {
    color: var(--color-byzantine-purple, #4a1e50);
    font-weight: 600;
  }
  .news-page-excerpt {
    margin: 0.5rem 0 0;
    font-size: 0.95rem;
    line-height: 1.55;
  }
</style>
