---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SaintCard from '../../components/SaintCard.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Strict per-locale filter: the Greek site shows ONLY language: el entries
// (per user directive — no English content visible on the Greek site).
// Bot-seeded English drafts still live on disk for future translation but
// don't render here.
const allSaints = (await getCollection('saints'))
  .filter(s => !s.data.draft)
  .filter(s => s.data.language === lang);

// Chronological sort: oldest -> newest by year of repose. Saints with no
// reposeYear sink to the bottom (sentinel = 9999).
const sorted = allSaints.slice().sort((a, b) => {
  const ay = a.data.reposeYear ?? 9999;
  const by = b.data.reposeYear ?? 9999;
  return ay - by;
});

// Per-category counts.
type Cat = 'martyr' | 'monastic' | 'hierarch' | 'apostle' | 'prophet' | 'other';
const cats: Cat[] = ['martyr', 'monastic', 'hierarch', 'apostle', 'prophet', 'other'];
const counts = Object.fromEntries(
  cats.map(c => [c, allSaints.filter(s => s.data.category === c).length])
) as Record<Cat, number>;
---

<BaseLayout title={t('all.saints')}>
  {lang === 'el' && (
    <div class="saints-disclaimer">
      <p>
        <strong>Ὁ κατάλογος δὲν εἶναι ἐξαντλητικός.</strong> Τὸ Οἰκουμενικὸ Πατριαρχεῖο
        δὲν δημοσιεύει ἀριθμητικῶς κλειστὸ συναξάριο· οἱ μνῆμες ἁγίων στὴν Ὀρθοδοξία
        ξεπερνοῦν τὶς δέκα χιλιάδες (πβ. Συναξαριστὴν Ἁγίου Νικοδήμου τοῦ Ἁγιορείτου,
        Μέγα Συναξαριστὴ Δουκάκη). Ἐδῶ παρουσιάζονται οἱ πιὸ γνωστοὶ καὶ ἀγαπημένοι
        ἅγιοι σὲ ἑλληνικὴ ἀπόδοση, μὲ εἰκόνες ἀπὸ τὸ Wikimedia Commons. Νέα κείμενα
        προστίθενται περιοδικά.
      </p>
    </div>
  )}

  <div class="saints-stats">
    <p class="muted total">
      <strong>{allSaints.length}</strong>
      {lang === 'el' ? 'ἅγιοι σὲ αὐτὸν τὸν κατάλογο' : 'saints in the calendar'}
    </p>
    <ul class="cat-counts">
      {cats.filter(c => counts[c] > 0).map(c => (
        <li><span class="cat-count">{counts[c]}</span> {t(`category.${c}` as any)}</li>
      ))}
    </ul>
  </div>

  {sorted.length === 0 ? (
    <p class="muted">{t('no.entries')}</p>
  ) : (
    <ul class="card-list">
      {sorted.map(s => (
        <li>
          <SaintCard
            slug={s.id}
            name={s.data.name}
            feastDay={s.data.feastDay}
            category={s.data.category}
            language={s.data.language}
            iconUrl={s.data.iconUrl}
            reposeLabel={s.data.reposeLabel}
          />
        </li>
      ))}
    </ul>
  )}
</BaseLayout>

<style>
  .saints-disclaimer {
    margin: 1rem 0 1.5rem;
    padding: 1rem 1.25rem;
    background: rgba(180, 145, 70, 0.08);
    border-left: 3px solid #b49146;
    border-radius: 2px;
  }
  .saints-disclaimer p { margin: 0; line-height: 1.55; font-size: 0.95rem; }
  .saints-stats {
    margin: 1rem 0 1.5rem;
    padding: 1rem 1.25rem;
    background: var(--color-surface, rgba(0,0,0,0.02));
    border-left: 3px solid var(--color-accent);
    border-radius: 2px;
  }
  .saints-stats .total {
    margin: 0 0 0.5rem;
    font-size: 1.05rem;
  }
  .saints-stats .total strong {
    color: var(--color-accent);
    font-size: 1.4rem;
    font-variant-numeric: tabular-nums;
  }
  .cat-counts {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.1rem;
    font-size: 0.92rem;
    color: var(--color-muted, #6e6452);
  }
  .cat-count {
    font-weight: 700;
    color: var(--color-text);
    font-variant-numeric: tabular-nums;
    margin-right: 0.25rem;
  }
  .card-list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
  }
</style>
