---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../../i18n/utils';
import type { UIKey } from '../../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const greekOnly = lang === 'el';

const articles = (await getCollection('articles'))
  .filter(a => !a.data.draft && a.data.tags && a.data.tags.length > 0)
  .filter(a => !greekOnly || a.data.language === 'el');

const clusters = [
  { id: 'spiritual',   primaryTag: 'spiritual-life', titleKey: 'theology.section.spiritual'  },
  { id: 'hesychasm',   primaryTag: 'hesychasm',      titleKey: 'theology.section.hesychasm'  },
  { id: 'philokalia',  primaryTag: 'philokalia',     titleKey: 'theology.section.philokalia' },
  { id: 'dogmatiki',   primaryTag: 'theology',       titleKey: 'theology.section.theology'   },
  { id: 'liturgika',   primaryTag: 'liturgical',     titleKey: 'theology.section.liturgical' },
  { id: 'iconography', primaryTag: 'iconography',    titleKey: 'theology.section.iconography'},
  { id: 'sacraments',  primaryTag: 'sacraments',     titleKey: 'theology.section.sacraments' },
  { id: 'clergy',      primaryTag: 'clergy',         titleKey: 'theology.section.clergy'     },
  { id: 'ecclesiology',primaryTag: 'ecclesiology',   titleKey: 'theology.section.ecclesiology'},
  { id: 'monasticism', primaryTag: 'monasticism',    titleKey: 'theology.section.monasticism'},
  { id: 'eschatology', primaryTag: 'eschatology',    titleKey: 'theology.section.eschatology'},
] as const;

const counts: Record<string, number> = {};
for (const cl of clusters) {
  counts[cl.id] = articles.filter(a => a.data.tags!.includes(cl.primaryTag)).length;
}

// Sort the cluster cards alphabetically by their Greek label.
const sortedClusters = [...clusters]
  .map(cl => ({ ...cl, title: t(cl.titleKey as UIKey) }))
  .sort((a, b) => a.title.localeCompare(b.title, 'el-GR'));
---

<BaseLayout title={t('theology.title')}>
  <h1>{t('theology.title')}</h1>
  <p class="muted">{t('theology.intro')}</p>

  <ul class="cluster-grid">
    {sortedClusters.map(cl => (
      <li class={`cluster-card ${counts[cl.id] === 0 ? 'is-empty' : ''}`}>
        <a href={getLocalizedPath(`/theology/${cl.id}`, lang)}>
          <h2>{cl.title}</h2>
          <p class="muted count">
            {counts[cl.id] === 0 ? 'σύντομα' : `${counts[cl.id]} ἄρθρα`}
          </p>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .cluster-grid {
    list-style: none;
    padding: 0;
    margin: 2rem 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }
  .cluster-card {
    border: 1px solid var(--color-border);
    border-radius: 4px;
    transition: border-color 0.15s;
  }
  .cluster-card:hover { border-color: var(--color-accent); }
  .cluster-card.is-empty { opacity: 0.55; }
  .cluster-card a {
    display: block;
    padding: 1.1rem 1.2rem;
    color: var(--color-text);
    border-bottom: none;
    height: 100%;
  }
  .cluster-card h2 {
    margin: 0 0 0.35rem;
    font-size: 1.1rem;
    line-height: 1.25;
  }
  .cluster-card .count {
    margin: 0;
    font-size: 0.88rem;
    font-variant-numeric: tabular-nums;
  }
</style>
